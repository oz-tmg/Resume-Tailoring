%% resume-ats.tex.j2
%% ATS-friendly single-column resume template.
%% Companion to resume.tex.j2 — same content, same pipeline outputs, but
%% laid out as a single column with section headings (no aside/sidebar)
%% so it parses cleanly through applicant tracking systems while keeping
%% the navy + atsblue identity from cv-style-ats.cls.
%%
%% Generated by resume-builder. DO NOT EDIT DIRECTLY.
%% Source: templates/resume-ats.tex.j2

\documentclass[]{cv-style-ats}
\sethyphenation[variant=british]{english}{}

%% Asset path — injected by renderer.py as the absolute path to the repo root.
%% Mirrors resume.tex.j2 so fonts/ and icons/ resolve regardless of the
%% output subdirectory the .tex file is compiled from.
\graphicspath{
  {<< assets_root >>/}
  {<< assets_root >>/icons/logos/}
  {<< assets_root >>/icons/main/}
  {./}
}

%% Personal-info macros — kept compatible with cv-style.cls so the same
%% content/personal.yaml drives both templates.
\newcommand{\myphone}{<< personal.phone >>}
\newcommand{\myemail}{<< personal.email >>}
\newcommand{\mylinkedin}{<< personal.linkedin_handle >>}
\newcommand{\mylinkedinpage}{<< personal.linkedin_url >>}
\newcommand{\myGithub}{<< personal.github_url >>}
\newcommand{\mylocation}{<< personal.location >>}

\begin{document}

%% -----------------------------------------------------------------------
%% HEADER — navy band with name, subtitle, keyword tagline, contact info
%% -----------------------------------------------------------------------
\atsheader%
  {<< personal.first_name >>}%
  {<< personal.last_name >>}%
  {\myphone}%
  {\href{mailto:\myemail}{\myemail}}%
  {\href{\mylinkedinpage}{\mylinkedin}}%
  {\href{\myGithub}{github.com/<< personal.github_handle >>}}%
  {<< personal.location >><% if personal.country is defined and personal.country %>, << personal.country | latex_escape >><% endif %>}%
  {<< header_title >>}%
  {<< ats_tagline >>}

%% -----------------------------------------------------------------------
%% PROFESSIONAL SUMMARY
%% -----------------------------------------------------------------------
\section{Professional Summary}
<< summary_text | latex_escape >>
<% if personal.work_authorization is defined and personal.work_authorization and personal.work_authorization.show_on_resume %>

\noindent\textit{<< personal.work_authorization.note | latex_escape >>}
<% endif %>

%% -----------------------------------------------------------------------
%% TECHNICAL SKILLS — key/value table
%% Driven by `ats_skills_groups` (composed by renderer._compose_ats_skills_groups
%% from skills.yaml + the family's optional ats_skills_groups override).
%% -----------------------------------------------------------------------
<% if ats_skills_groups %>
\section{Technical Skills}
\begin{techskills}
<% for grp in ats_skills_groups %>
\skillgroup{<< grp.label | latex_escape >>}{<< grp.items_text | latex_escape >>}
<% endfor %>
\end{techskills}
<% endif %>

%% -----------------------------------------------------------------------
%% KEY IMPACT METRICS — 4-up callout (or 3-up via impactbox*)
%% Driven by family.impact_metrics. Section is omitted when absent.
%% -----------------------------------------------------------------------
<% if impact_metrics %>
\section{Key Impact Metrics}
<% if impact_metrics | length == 3 %>
\begin{impactbox*}
<% else %>
\begin{impactbox}
<% endif %>
<% for m in impact_metrics %>
\impactcell{<< m.value | latex_escape >>}{<< m.label | latex_escape >>}<% if not loop.last %> &<% endif %>
<% endfor %>
<% if impact_metrics | length == 3 %>
\end{impactbox*}
<% else %>
\end{impactbox}
<% endif %>
<% endif %>

%% -----------------------------------------------------------------------
%% PROFESSIONAL EXPERIENCE
%% Same data model as resume.tex.j2 — companies → roles → bullets, with
%% optional split_sections (Responsibilities + Outcomes) when the role
%% is configured for it in the family file.
%% -----------------------------------------------------------------------
\section{Professional Experience}

<% for company in experience %>
<% set ns = namespace(first_role=true) %>
<% for role in company.roles %>
<% if ns.first_role %>
\jobcompany{<< company.company | latex_escape >>}{<% if company.division %><< company.division | latex_escape >><% endif %>}
<% set ns.first_role = false %>
<% endif %>
\jobrole{<< role.title | latex_escape >>}{<< role.start >> -- << role.end >>}
<% if role.resolved_summary is defined and role.resolved_summary %>
\jobsummary{<< role.resolved_summary | latex_escape >>}
<% endif %>
<%- if role._split_sections is defined and role._split_sections -%>
<%- set work_bs    = role.bullets | selectattr("category", "equalto", "work")    | list -%>
<%- set outcome_bs = role.bullets | selectattr("category", "equalto", "outcome") | list -%>
<% if work_bs and outcome_bs %>
\jobsubhead{Responsibilities}
\begin{jobbullets}
<% for bullet in work_bs %>
  \item << bullet.resolved_text | latex_escape >>
<% if bullet.resolved_subs is defined and bullet.resolved_subs %>
  \begin{jobbullets}
<% for sub in bullet.resolved_subs %>
    \item << sub.resolved_text | latex_escape >>
<% endfor %>
  \end{jobbullets}
<% endif %>
<% endfor %>
\end{jobbullets}
\jobsubhead{Outcomes}
\begin{jobbullets}
<% for bullet in outcome_bs %>
  \item << bullet.resolved_text | latex_escape >>
<% endfor %>
\end{jobbullets}
<% else %>
\begin{jobbullets}
<% for bullet in role.bullets %>
  \item << bullet.resolved_text | latex_escape >>
<% if bullet.resolved_subs is defined and bullet.resolved_subs %>
  \begin{jobbullets}
<% for sub in bullet.resolved_subs %>
    \item << sub.resolved_text | latex_escape >>
<% endfor %>
  \end{jobbullets}
<% endif %>
<% endfor %>
\end{jobbullets}
<% endif %>
<%- else -%>
\begin{jobbullets}
<% for bullet in role.bullets %>
  \item << bullet.resolved_text | latex_escape >>
<% if bullet.resolved_subs is defined and bullet.resolved_subs %>
  \begin{jobbullets}
<% for sub in bullet.resolved_subs %>
    \item << sub.resolved_text | latex_escape >>
<% endfor %>
  \end{jobbullets}
<% endif %>
<% endfor %>
\end{jobbullets}
<%- endif -%>
<% endfor %>
<% endfor %>

%% -----------------------------------------------------------------------
%% EDUCATION — two-column when 2 entries fit; otherwise single-column list
%% Accomplishments are intentionally omitted in the ATS layout to keep the
%% section to a compact strip at the bottom of the resume (matching the
%% recruiter-prepared layout). If certs_placement=="education", certs
%% follow as a compact bulleted list below.
%% -----------------------------------------------------------------------
\section{Education}
<% if education | length == 2 %>
\begin{edublock}
  \edudegree{<< education[0].degree | latex_escape >><% if education[0].minor is defined and education[0].minor %> (Minor: << education[0].minor | latex_escape >>)<% endif %>}%
            {<< education[0].institution | latex_escape >>}%
            {<< education[0].start >> -- << education[0].end >>}
  &
  \edudegree{<< education[1].degree | latex_escape >><% if education[1].minor is defined and education[1].minor %> (Minor: << education[1].minor | latex_escape >>)<% endif %>}%
            {<< education[1].institution | latex_escape >>}%
            {<< education[1].start >> -- << education[1].end >>}
\end{edublock}
<% else %>
<% for edu in education %>
\edusingle{<< edu.degree | latex_escape >><% if edu.minor is defined and edu.minor %> (Minor: << edu.minor | latex_escape >>)<% endif %>}%
          {<< edu.institution | latex_escape >>}%
          {<< edu.start >> -- << edu.end >>}
<% endfor %>
<% endif %>

<% if certifications %>
%% -----------------------------------------------------------------------
%% CERTIFICATIONS — only rendered when certs_placement is "education".
%% -----------------------------------------------------------------------
\section{Certifications}
\begin{certlist}
<% for cert in certifications %>
\certentry{<< cert.name | latex_escape >>}{<< cert.issuer | latex_escape >>}{<< cert.year >>}
<% endfor %>
\end{certlist}
<% endif %>

\end{document}
