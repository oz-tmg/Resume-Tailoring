# .envrc — direnv + uv environment setup
#
# On first `cd` into this directory (after `direnv allow`), direnv will:
#   1. Create a .venv via uv if one doesn't exist
#   2. Activate it for the shell session
#   3. Export ANTHROPIC_API_KEY (and any other vars) from a local .env file
#
# Prerequisites:
#   brew install direnv uv
#   echo 'eval "$(direnv hook zsh)"' >> ~/.zshrc   # or bash equivalent

# ── Python venv via uv ──────────────────────────────────────────────────────
export VIRTUAL_ENV="$PWD/.venv"

if [ ! -d "$VIRTUAL_ENV" ]; then
    echo "direnv: creating .venv with uv (Python $(cat .python-version))..."
    uv venv "$VIRTUAL_ENV" --python "$(cat .python-version)"
    uv pip install -r requirements.txt
fi

PATH_add "$VIRTUAL_ENV/bin"
export UV_PROJECT_ENVIRONMENT="$VIRTUAL_ENV"

# ── Local .env (API keys, secrets — not committed) ──────────────────────────
# Loads ANTHROPIC_API_KEY and any other vars you keep in .env
dotenv_if_exists .env
